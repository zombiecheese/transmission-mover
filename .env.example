APP_NAME=Transmission Mover
POLL_SECONDS=20
DATABASE_URL=sqlite:///./data/app.db
LOG_LEVEL=INFO
# Initial web auth setup (only used on first startup if no credentials exist in database)
WEB_AUTH_USERNAME=
WEB_AUTH_PASSWORD=
# Fernet key for encrypting secrets (auto-generated if not set)
SECRET_ENCRYPTION_KEY=
